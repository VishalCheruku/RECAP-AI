# Backend Environment Variables (copy to .env and fill in your values)

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGO_DB_NAME=recap_ai

# Twilio SMS (optional, leave blank if not using)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Voice Call API (optional)
VOICE_API_KEY=your_voice_api_key

# Frontend URL (for CORS - set when deploying to production)
FRONTEND_URL=http://localhost:3000
